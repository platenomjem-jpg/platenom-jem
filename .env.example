# قاعدة البيانات - Railway يوفرها تلقائياً عند إضافة PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/sports_club_db

# منفذ السيرفر
PORT=3000

# مفتاح تشفير الجلسات والتوكنات - غيّره لقيمة عشوائية قوية في الإنتاج
SESSION_SECRET=change_this_to_a_random_secure_string
JWT_SECRET=change_this_to_another_random_secure_string

# بيئة التشغيل
NODE_ENV=development
